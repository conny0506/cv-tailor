# Anthropic API key — required.
# Get yours at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# GitHub Personal Access Token — optional but strongly recommended.
# Without a token: 60 req/h shared rate limit (will fail after 1-2 syncs).
# With a token (any classic PAT, no scopes needed for public repos): 5000 req/h.
# Create at https://github.com/settings/tokens (classic) or fine-grained.
GITHUB_PAT=

# ─── Vercel-only env vars ────────────────────────────────────────────────────
# CV_JSON: data/cv.json içeriğinin tamamını buraya yapıştır (tek satır JSON).
# Vercel dashboard → Settings → Environment Variables'a ekle.
# CV_JSON={"personal":{...},"summary":{...},...}

# KV_REST_API_URL ve KV_REST_API_TOKEN: Vercel KV veritabanı oluşturulunca
# otomatik olarak proje env vars'larına eklenir — elle girmen gerekmez.
# KV_REST_API_URL=https://...
# KV_REST_API_TOKEN=...
